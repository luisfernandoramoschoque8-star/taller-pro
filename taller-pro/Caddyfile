{
	frankenphp
}

:8080 {
	root * /app/public
	encode zstd br gzip

	# Nota: CORS lo maneja Laravel (fruitcake/laravel-cors)
	# No añadir headers CORS aquí para evitar duplicados

	# PHP (FrankenPHP) + routing Laravel con query string preservado
	route {
		try_files {path} {path}/ /index.php?{query}
		php_server
		file_server
	}
}

