{
	frankenphp
}

:8080 {
	root * /app/public
	encode zstd br gzip

	# CORS para el frontend en Vercel
	@api path /api/*
	header @api {
		Access-Control-Allow-Origin https://taller-pro-three.vercel.app
		Access-Control-Allow-Methods "GET, POST, PUT, PATCH, DELETE, OPTIONS"
		Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With"
		Access-Control-Max-Age 86400
		Vary Origin
	}

	# Responder preflight (OPTIONS) asegurando incluir los headers CORS anteriores
	@options {
		method OPTIONS
		path /api/*
	}
	respond @options 204

	# PHP (FrankenPHP) + routing Laravel con query string preservado
	php_server
	route {
		file_server
		try_files {path} {path}/ /index.php?{query}
	}
}

